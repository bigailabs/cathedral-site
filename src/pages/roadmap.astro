---
import Base from '../layouts/Base.astro'

type Issue = {
  number: number
  title: string
  state: 'open' | 'closed'
  html_url: string
  labels: { name: string }[]
  pull_request?: unknown
}

const ACTS = [
  {
    id: 'act-1',
    title: 'act 1 · baseline stability',
    blurb: 'validator + miner run reliably. stake unlocks weights. security hardening on the rest api.',
  },
  {
    id: 'act-2',
    title: 'act 2 · profitability',
    blurb: 'close the loop: rented gpus mine other subnets, revenue flows back. agent-safe rentals.',
  },
  {
    id: 'act-3',
    title: 'act 3 · ecosystem + flywheel',
    blurb: 'external miners. subnet scouting. treasury dashboard. compute in, mining out, p&l in the open.',
  },
] as const

async function fetchIssues(): Promise<Issue[]> {
  try {
    const headers: Record<string, string> = {
      'Accept': 'application/vnd.github+json',
      'User-Agent': 'cathedral-site',
    }
    const token = import.meta.env.GITHUB_TOKEN
    if (token) headers.Authorization = `Bearer ${token}`
    const r = await fetch(
      'https://api.github.com/repos/bigailabs/cathedral/issues?state=all&per_page=100',
      { headers },
    )
    if (!r.ok) return []
    const data = (await r.json()) as Issue[]
    return data.filter((i) => !i.pull_request)
  } catch {
    return []
  }
}

const issues = await fetchIssues()

function forAct(actId: string): Issue[] {
  return issues
    .filter((i) => i.labels.some((l) => l.name === actId))
    .sort((a, b) => {
      const aEpic = a.labels.some((l) => l.name === 'epic') ? 0 : 1
      const bEpic = b.labels.some((l) => l.name === 'epic') ? 0 : 1
      if (aEpic !== bEpic) return aEpic - bEpic
      if (a.state !== b.state) return a.state === 'open' ? -1 : 1
      return a.number - b.number
    })
}

const unlabeled = issues.filter((i) => !i.labels.some((l) => /^act-[123]$/.test(l.name)))
const total = issues.length
const openCount = issues.filter((i) => i.state === 'open').length
---

<Base title="roadmap · cathedral">
  <div class="max-w-[820px] w-full mx-auto space-y-10 py-4">
    <section>
      <h1 class="text-[15px] text-fg mb-1">roadmap</h1>
      <p class="text-[12px] text-muted leading-relaxed">
        the commitment is the three acts, in order. individual issues are a
        speculative early draft — scope, sequencing, and priorities will change
        as we learn. items can be dropped, split, or rewritten.
      </p>
      <p class="text-[11.5px] text-dim leading-relaxed mt-2">
        live from <a href="https://github.com/bigailabs/cathedral/issues" class="text-muted hover:text-fg underline underline-offset-2 decoration-dim">github issues</a> · no private backlog
      </p>
      {total > 0 && (
        <p class="text-[11px] text-dim mt-3 tabular-nums">
          {openCount} open · {total - openCount} closed · {total} total
        </p>
      )}
    </section>

    {total === 0 && (
      <section>
        <p class="text-[12px] text-muted">
          couldn't reach github at build time. see the
          <a href="https://github.com/bigailabs/cathedral/issues" class="text-accent hover:underline underline-offset-2 ml-1">issue tracker</a>.
        </p>
      </section>
    )}

    {ACTS.map((act) => {
      const items = forAct(act.id)
      return (
        <section>
          <div class="flex items-baseline justify-between gap-4 mb-2">
            <h2 class="text-[13px] text-fg">{act.title}</h2>
            <span class="text-[9px] uppercase tracking-[0.15em] text-accent border border-accent/40 px-1.5 py-0.5 shrink-0">
              commitment
            </span>
          </div>
          <p class="text-[11.5px] text-muted mb-4 leading-relaxed">{act.blurb}</p>

          <div class="flex items-baseline justify-between gap-4 mb-2">
            <h3 class="text-[11px] text-dim uppercase tracking-[0.15em]">current slice · draft</h3>
            <span class="text-[11px] text-dim tabular-nums shrink-0">
              {items.filter((i) => i.state === 'open').length} open / {items.length}
            </span>
          </div>
          {items.length === 0 ? (
            <p class="text-[11.5px] text-dim italic">nothing filed yet</p>
          ) : (
            <ul class="space-y-0 divide-y divide-border border-t border-b border-border">
              {items.map((i) => {
                const isEpic = i.labels.some((l) => l.name === 'epic')
                const isSec = i.labels.some((l) => l.name === 'security')
                return (
                  <li>
                    <a
                      href={i.html_url}
                      class="flex items-start gap-3 px-1 py-2 hover:bg-surface transition-colors group"
                    >
                      <span class={`shrink-0 text-[10px] tabular-nums w-8 ${i.state === 'open' ? 'text-accent' : 'text-dim'}`}>
                        #{i.number}
                      </span>
                      <span class="flex-1 min-w-0 text-[12px] text-fg group-hover:text-accent transition-colors">
                        {i.title}
                      </span>
                      <span class="shrink-0 flex items-center gap-1.5">
                        {isEpic && (
                          <span class="text-[9px] text-accent uppercase tracking-[0.1em]">epic</span>
                        )}
                        {isSec && (
                          <span class="text-[9px] text-warn uppercase tracking-[0.1em]">sec</span>
                        )}
                        <span class={`text-[9px] uppercase tracking-[0.1em] ${i.state === 'open' ? 'text-muted' : 'text-dim'}`}>
                          {i.state}
                        </span>
                      </span>
                    </a>
                  </li>
                )
              })}
            </ul>
          )}
        </section>
      )
    })}

    {unlabeled.length > 0 && (
      <section>
        <h2 class="text-[13px] text-fg mb-3">unscoped</h2>
        <p class="text-[11.5px] text-muted mb-3 leading-relaxed">
          filed but not yet assigned to an act.
        </p>
        <ul class="space-y-0 divide-y divide-border border-t border-b border-border">
          {unlabeled.map((i) => (
            <li>
              <a href={i.html_url} class="flex items-start gap-3 px-1 py-2 hover:bg-surface transition-colors group">
                <span class={`shrink-0 text-[10px] tabular-nums w-8 ${i.state === 'open' ? 'text-accent' : 'text-dim'}`}>
                  #{i.number}
                </span>
                <span class="flex-1 min-w-0 text-[12px] text-fg group-hover:text-accent transition-colors">
                  {i.title}
                </span>
                <span class={`shrink-0 text-[9px] uppercase tracking-[0.1em] ${i.state === 'open' ? 'text-muted' : 'text-dim'}`}>
                  {i.state}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="pt-4 border-t border-border">
      <p class="text-[11px] text-dim leading-relaxed">
        something missing? <a href="https://github.com/bigailabs/cathedral/issues/new" class="text-muted hover:text-fg underline underline-offset-2 decoration-dim">file it</a>.
      </p>
    </section>
  </div>
</Base>
