---
import Base from '../layouts/Base.astro'

const minerToml = `bid_grpc_port = 50052

[bittensor]
wallet_name    = "your_wallet"
hotkey_name    = "your_hotkey"
network        = "finney"
netuid         = 39
chain_endpoint = "wss://entrypoint-finney.opentensor.ai:443"
axon_port      = 50051

[database]
url = "sqlite:/opt/cathedral/data/miner.db?mode=rwc"

[node_management]
nodes = [
  { host = "<your.gpu.ip>", port = 22, username = "root", gpu_category = "RTX3090", gpu_count = 1 },
]

[ssh_session]
miner_node_key_path   = "/root/.ssh/miner_key"
default_node_username = "root"

[validator_assignment]
strategy               = "fixed_assignment"
validator_hotkey       = "5DnvAgAVykQFmgTSwLXTHpzfmi6W32VtV8L1D9yxSmtThWPb"
grpc_endpoint_override = "http://135.181.8.214:50052"

[bidding.strategy.static.static_prices]
RTX3090 = 0.28
RTX4090 = 0.45
RTX5090 = 0.45
`

const GPU_TIERS = [
  { name: 'entry-gaming',     examples: 'RTX 3060 12GB · 4060 · 5060',                vram: '8–12 GB',  price: '$0.08' },
  { name: 'mid-gaming',       examples: 'RTX 3070 · 4070 · 5070 · 4070 Ti',           vram: '12–16 GB', price: '$0.14' },
  { name: 'high-gaming',      examples: 'RTX 3080 · 3080 Ti · 4070 Ti Super',         vram: '12–16 GB', price: '$0.18' },
  { name: 'flagship-gaming',  examples: 'RTX 3090 · 3090 Ti · 4080 · 5080',           vram: '16–24 GB', price: '$0.28' },
  { name: 'flagship-plus',    examples: 'RTX 4090 · 5090',                            vram: '24–32 GB', price: '$0.45' },
  { name: 'workstation',      examples: 'RTX 6000 Ada · W7900',                       vram: '48 GB',    price: '$0.75' },
  { name: 'workstation-plus', examples: 'RTX Pro 6000 Blackwell',                     vram: '96 GB',    price: '$1.30' },
  { name: 'apple-silicon',    examples: 'M2/M3/M4 Ultra · Studio · Mac Pro',          vram: 'unified',  price: 'by memory' },
  { name: 'dgx-spark',        examples: 'DGX Spark · Blackwell Desktop',              vram: 'varies',   price: 'by vram' },
] as const
---

<Base title="mine · cathedral">
  <style>
    .eyebrow {
      font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--dim); display: flex; align-items: baseline; gap: 10px;
    }
    .eyebrow .num { font-variant-numeric: tabular-nums; color: var(--accent); }
    .sec { padding: 56px 0; border-bottom: 1px solid var(--border-soft); }
    .sec:last-of-type { border-bottom: 0; }
    .sec .wrap { display: grid; grid-template-columns: 160px 1fr; gap: 48px; }
    @media (max-width: 900px) {
      .sec { padding: 44px 0; } .sec .wrap { grid-template-columns: 1fr; gap: 20px; }
    }
    .lede {
      font-family: var(--font-serif, 'Newsreader', ui-serif, Georgia, serif);
      font-size: 20px; font-weight: 300; line-height: 1.45; color: var(--fg);
      max-width: 34ch; margin: 0;
    }
    .lede em { font-style: italic; color: var(--muted); }
    .beta-tag {
      display: inline-block; font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--warn); border: 1px solid var(--warn); padding: 2px 6px;
      margin-left: 10px; vertical-align: middle;
    }
    .tiers { width: 100%; border-collapse: collapse; font-size: 12px; }
    .tiers td { padding: 10px 12px 10px 0; border-bottom: 1px solid var(--border-soft); }
    .tiers td.name  { color: var(--accent); width: 28%; font-variant-numeric: tabular-nums; }
    .tiers td.ex    { color: var(--fg); }
    .tiers td.vram  { color: var(--dim); text-align: right; width: 18%; font-variant-numeric: tabular-nums; }
    .tiers td.price { color: var(--fg); text-align: right; width: 14%; font-variant-numeric: tabular-nums; }
    pre.code {
      background: var(--surface); border: 1px solid var(--border);
      padding: 14px 16px; font-size: 11.5px; line-height: 1.6;
      overflow-x: auto; color: var(--fg);
    }
    .limitations li { position: relative; padding-left: 16px; color: var(--fg); font-size: 12px; line-height: 1.7; }
    .limitations li::before { content: '—'; position: absolute; left: 0; color: var(--warn); }
    .limitations li em { color: var(--warn); font-style: normal; }
  </style>

  <section class="sec">
    <div class="wrap">
      <div><div class="eyebrow"><span class="num">00</span><span>Mine</span></div></div>
      <div>
        <p class="lede">Bring your gaming PC.<br/><em>Cathedral is for home-ownable compute.</em></p>
        <p class="text-[12px] text-muted leading-relaxed max-w-[56ch] mt-4">
          Consumer GPUs, workstations, Apple Silicon, DGX Spark. No data-center rentals.
          Our validator verifies the card over SSH and routes work.
          <span class="beta-tag">beta</span>
        </p>
        <p class="text-[11px] text-dim leading-relaxed mt-3">
          Beta software on a live subnet. Looking to rent compute instead?
          <a href="https://polaris.computer" class="text-muted hover:text-fg underline underline-offset-2 decoration-dim">polaris.computer</a>.
        </p>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div>
        <div class="eyebrow"><span class="num">01</span><span>Supported hardware</span></div>
        <p class="text-[11px] text-muted mt-4 leading-relaxed max-w-[28ch]">
          Consumer, workstation, Apple. Data-center SKUs intentionally rejected.
        </p>
      </div>
      <div>
        <table class="tiers">
          <tbody>
            {GPU_TIERS.map((t) => (
              <tr>
                <td class="name">{t.name}</td>
                <td class="ex">{t.examples}</td>
                <td class="vram">{t.vram}</td>
                <td class="price">{t.price}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <p class="text-[11px] text-dim leading-relaxed mt-4 max-w-[64ch]">
          A100, H100, MI300, etc. are rejected at registration. Operate one at home and want an exception?
          <a href="https://github.com/bigailabs/cathedral/issues" class="text-muted hover:text-fg underline underline-offset-2 decoration-dim">Open an issue</a>.
        </p>
        <p class="text-[11px] text-warn leading-relaxed mt-2">Minimum VRAM floor: 7 GB.</p>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div><div class="eyebrow"><span class="num">02</span><span>Prerequisites</span></div></div>
      <div>
        <ul class="limitations space-y-1.5 list-none">
          <li>Bittensor hotkey registered on netuid 39</li>
          <li>A GPU node from the list above · Linux or Apple Silicon · SSH reachable</li>
          <li>For Nvidia: CUDA 12.x · Docker with Nvidia runtime</li>
          <li>A separate CPU-only host for the miner process (any cheap VPS)</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div><div class="eyebrow"><span class="num">03</span><span>Validator endpoint</span></div></div>
      <div>
<pre class="code">hotkey    5DnvAgAVykQFmgTSwLXTHpzfmi6W32VtV8L1D9yxSmtThWPb
grpc      http://135.181.8.214:50052
axon      135.181.8.214:8080</pre>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div><div class="eyebrow"><span class="num">04</span><span>miner.toml</span></div></div>
      <div><pre class="code">{minerToml}</pre></div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div><div class="eyebrow"><span class="num">05</span><span>Build &amp; run</span></div></div>
      <div>
<pre class="code"># on an x86_64 linux box
apt-get install -y protobuf-compiler pkg-config libssl-dev build-essential
curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
source ~/.cargo/env

git clone https://github.com/bigailabs/cathedral.git
cd cathedral
cargo build --release --package basilica-miner

./target/release/cathedral-miner --config /path/to/miner.toml</pre>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div><div class="eyebrow"><span class="num">06</span><span>Expected logs</span></div></div>
      <div>
<pre class="code" style="color: var(--muted);">INFO  registering nodes with validator   miner_hotkey=5... node_count=1
INFO  successfully registered             registration_id=reg-... has_ssh_key=true
INFO  deploying validator ssh key to nodes
INFO  deployed ssh keys for validator     nodes=1
INFO  starting lifecycle loop             health_check=60s</pre>
        <p class="text-[11px] text-muted mt-4 leading-relaxed max-w-[56ch]">
          Watch the validator side on <a href="/" class="text-muted hover:text-fg underline underline-offset-2 decoration-dim">the home page</a>.
          Next verification cycle runs every ~10 min; your UID appears in the miners register once seen.
          Long-form guide at <a href="https://github.com/bigailabs/cathedral/blob/main/docs/miner.md" class="text-muted hover:text-fg underline underline-offset-2 decoration-dim">docs/miner.md</a>.
        </p>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div><div class="eyebrow"><span class="num">07</span><span>Known limitations</span></div></div>
      <div>
        <ul class="limitations space-y-2 list-none">
          <li>Weights are <em>parked</em> — we're below SN39's ~14k α permit stake threshold. CUs accrue; emissions flow once weights unlock.</li>
          <li>Binary GPU attestation is <em>disabled</em>. Verification runs over SSH via <code style="color:var(--muted)">nvidia-smi</code>. Spoofable for now — prover binary lands later.</li>
          <li>GPU allow-list is a <em>string match</em> on <code style="color:var(--muted)">nvidia-smi</code> output. Audit tracked in <a href="https://github.com/bigailabs/cathedral/issues/24" class="text-muted hover:text-fg underline underline-offset-2 decoration-dim">#24</a>.</li>
          <li>Apple Silicon verification isn't wired yet. Nvidia works today, Apple lands in Act 2.</li>
          <li>Act 2 is about making mining economically coherent. Until it lands, the incentive is pre-emission CUs plus bootstrap participation.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="sec">
    <div class="wrap">
      <div><div class="eyebrow"><span class="num">08</span><span>Disclaimer</span></div></div>
      <div>
        <p class="text-[12px] text-muted leading-relaxed max-w-[64ch]">
          Cathedral is early software on a live subnet. No SLA, no uptime guarantee, no promise of yield.
          Hotkeys and SSH keys you deploy are your responsibility. Code is
          <a href="https://github.com/bigailabs/cathedral/blob/main/LICENSE" class="text-muted hover:text-fg underline underline-offset-2 decoration-dim">MIT-licensed</a>, operated under
          <a href="https://github.com/bigailabs/cathedral/blob/main/docs/policy.md" class="text-muted hover:text-fg underline underline-offset-2 decoration-dim">the policy</a>.
          Run at your own risk.
        </p>
      </div>
    </div>
  </section>
</Base>
