  <!--
    Signup submission — plain client-side fetch, no framework.
    The API base is rendered onto the .signup element so this script can
    stay a generic is:inline block. Validation mirrors the server's
    required set; the server is still authoritative.
  -->
  <script is:inline>
    (function () {
      var root = document.querySelector('.signup')
      if (!root) return
      var form = root.querySelector('#cathedral-signup-form')
      if (!form) return
      var apiBase = root.getAttribute('data-api-base') || 'https://api.polaris.computer'
      var formError = root.querySelector('.form-error')
      var thanks = root.querySelector('.thanks')
      var submitBtn = form.querySelector('button[type="submit"]')

      // Required text fields. Hardware is validated separately (radio group).
      var TEXT_FIELDS = ['name', 'email', 'country', 'excites', 'blocker']
      var EMAIL_RE = /^[^@\s]+@[^@\s]+\.[^@\s]+$/

      function fieldEl(key) { return root.querySelector('[data-field="' + key + '"]') }
      function markError(key, on) {
        var el = fieldEl(key)
        if (!el) return
        if (on) el.classList.add('err')
        else el.classList.remove('err')
      }
      function getVal(key) {
        var input = form.querySelector('[name="' + key + '"]')
        return input ? String(input.value || '').trim() : ''
      }
      function validateOne(key) {
        var val = getVal(key)
        if (!val) { markError(key, true); return false }
        if (key === 'email' && !EMAIL_RE.test(val)) { markError(key, true); return false }
        markError(key, false)
        return true
      }

      // Blur validation — only fires after the user interacts with a field.
      TEXT_FIELDS.forEach(function (key) {
        var input = form.querySelector('[name="' + key + '"]')
        if (!input) return
        input.addEventListener('blur', function () { validateOne(key) })
        input.addEventListener('input', function () {
          // Clear the error as the user fixes it; final check on submit.
          if (fieldEl(key) && fieldEl(key).classList.contains('err')) markError(key, false)
        })
      })

      form.querySelectorAll('input[name="hardware"]').forEach(function (r) {
        r.addEventListener('change', function () { markError('hardware', false) })
      })

      function showFormError(msg) {
        if (!formError) return
        formError.textContent = msg
        formError.classList.add('show')
      }
      function hideFormError() {
        if (!formError) return
        formError.textContent = ''
        formError.classList.remove('show')
      }

      form.addEventListener('submit', async function (e) {
        e.preventDefault()
        hideFormError()

        var ok = true
        TEXT_FIELDS.forEach(function (k) { if (!validateOne(k)) ok = false })
        var hw = form.querySelector('input[name="hardware"]:checked')
        if (!hw) { markError('hardware', true); ok = false }
        if (!ok) {
          var firstBad = root.querySelector('.field.err input, .field.err textarea')
          if (firstBad) firstBad.focus()
          return
        }

        var payload = {
          name: getVal('name'),
          email: getVal('email').toLowerCase(),
          country: getVal('country'),
          hardware: hw.value,
          excites: getVal('excites'),
          blocker: getVal('blocker'),
        }

        submitBtn.disabled = true
        var originalLabel = submitBtn.textContent
        submitBtn.textContent = 'Signing...'

        try {
          var res = await fetch(apiBase + '/api/v1/cathedral/signup', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          })
          var data = null
          try { data = await res.json() } catch (_) { data = null }

          if (!res.ok || !data || !data.ok) {
            var msg = (data && (data.detail || data.error))
              || (res.status === 429 ? 'Too many requests. Give it a minute.' : 'Could not save your signup. Try again shortly.')
            showFormError(typeof msg === 'string' ? msg : 'Could not save your signup. Try again shortly.')
            return
          }

          // Success — swap the form for the thank-you panel.
          form.style.display = 'none'
          if (thanks) thanks.classList.add('show')
          if (thanks && 'scrollIntoView' in thanks) {
            thanks.scrollIntoView({ behavior: 'smooth', block: 'start' })
          }
        } catch (err) {
          showFormError('Network error. Check your connection and try again.')
        } finally {
          submitBtn.disabled = false
          submitBtn.textContent = originalLabel
        }
      })
    })()
  </script>

