---
/**
 * MinersRegister — right-side panel on the home dashboard.
 *
 * Shows the SN39 metagraph as a live register of masons (user-facing
 * term for SN39 miners — see also the mason/cathedral frame on /mine
 * and /afrotensor). Each row has:
 *   - uid
 *   - hotkey (abbreviated)
 *   - state pill (ours · active · inactive · verifying · rejected)
 *
 * Three dynamic behaviors, driven from the outer page script:
 *   1. When a validator log line names a UID, the matching row pulses accent.
 *   2. When a validator log line classifies a miner as rejected/invalid,
 *      the row flips to rejected state and animates to the top of the list.
 *   3. Our validator (uid 123) and our miner (uid 115) are always pinned
 *      with a subtle marker so you can find them.
 *
 * All data comes from /api/substrate/state (same endpoint ledger uses).
 */
---

<section
  class="flex flex-col min-h-0 border border-border bg-surface overflow-hidden"
  data-miners-register
>
  <header class="flex items-center gap-2 px-3 py-2 border-b border-borderSoft bg-surface2 text-[10px] uppercase tracking-[0.14em] text-dim shrink-0">
    <span class="inline-flex gap-1 shrink-0" aria-hidden="true">
      <span class="h-1.5 w-1.5 rounded-full bg-border"></span>
      <span class="h-1.5 w-1.5 rounded-full bg-border"></span>
      <span class="h-1.5 w-1.5 rounded-full bg-border"></span>
    </span>
    <span class="text-muted">sn39 · masons</span>
    <span class="text-dim">·</span>
    <span class="text-accent font-[500] tracking-[0.22em]">REGISTER</span>
    <span class="flex-1"></span>
    <span class="tabular-nums text-dim" data-miners-count>—</span>
  </header>

  <div class="flex-1 min-h-0 overflow-y-auto" data-miners-list>
    <div class="miners-placeholder px-3 py-4 text-[11px] text-dim">loading…</div>
  </div>

  <footer class="flex items-center gap-2 px-3 py-1.5 border-t border-borderSoft bg-surface2 text-[9px] uppercase tracking-[0.18em] text-dim shrink-0">
    <span data-miners-active-count>—</span>
    <span>·</span>
    <span data-miners-pending>—</span>
    <span class="flex-1"></span>
    <span class="text-accent">last seen</span>
    <span class="tabular-nums text-muted" data-miners-updated>—</span>
  </footer>
</section>
