---
interface Props {
  /** Data source id — used in data attributes so the JS hook finds this stream */
  id: 'validator' | 'miner'
  /** Header label */
  label: string
  /** Host shown in the header */
  host: string
  /** Role tag (VERIFY / PROVIDE / SOON) — right side of the title */
  role?: string
  /** Terminal index (T1 / T2 / T3) — small tag next to the title */
  terminalIndex?: string
}

const { id, label, host, role = 'VERIFY', terminalIndex = 'T1' } = Astro.props
---

<section
  class="flex flex-col min-h-0 border border-border bg-surface overflow-hidden"
  data-stream={id}
>
  <header class="flex items-center gap-2 px-3 py-2 border-b border-borderSoft bg-surface2 text-[10px] uppercase tracking-[0.14em] shrink-0">
    <span class="inline-flex gap-1 shrink-0" aria-hidden="true">
      <span class="h-1.5 w-1.5 rounded-full bg-border"></span>
      <span class="h-1.5 w-1.5 rounded-full bg-border"></span>
      <span class="h-1.5 w-1.5 rounded-full bg-border"></span>
    </span>
    <span class="text-muted min-w-0 truncate">
      cathedral-{label}
      <span class="text-accent font-[500] ml-1">{terminalIndex}</span>
      <span class="text-dim ml-2 normal-case tracking-normal">· {host}</span>
    </span>
    <span class="flex-1"></span>
    <span class="text-accent border border-border px-1.5 py-0.5 tracking-[0.22em] text-[9px] shrink-0">{role}</span>
    <span class="flex items-center gap-1.5 text-dim shrink-0 ml-2 normal-case tracking-normal text-[10px]">
      <span data-freshness class="tabular-nums"></span>
      <span class="relative flex h-1.5 w-1.5" data-live-indicator>
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-60"></span>
        <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-accent"></span>
      </span>
      <span data-status>live</span>
    </span>
  </header>
  <div
    class="flex-1 min-h-0 overflow-y-auto px-3 py-2 text-[12px] leading-[1.65]"
    data-log-body
  >
    <div class="text-dim" data-empty>connecting…</div>
  </div>
</section>
