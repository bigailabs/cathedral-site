---
interface Props {
  title?: string
  /** When true, the page fills the viewport exactly — use for the log dashboard. */
  fullHeight?: boolean
}

const { title = 'cathedral', fullHeight = false } = Astro.props

const shellClass = fullHeight
  ? 'mx-auto max-w-[1180px] h-screen flex flex-col px-5 py-4'
  : 'mx-auto max-w-[1180px] min-h-screen flex flex-col px-5 py-5'
const mainClass = fullHeight
  ? 'flex-1 min-h-0 flex flex-col'
  : 'flex-1 flex flex-col'
const footerClass = fullHeight
  ? 'mt-3 pt-2 text-[10px] text-dim flex items-center gap-3 shrink-0'
  : 'mt-8 pt-3 text-[10px] text-dim flex items-center gap-3'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme')
          var prefersLight = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches
          var theme = saved || (prefersLight ? 'light' : 'dark')
          document.documentElement.setAttribute('data-theme', theme)
        } catch (_) {
          document.documentElement.setAttribute('data-theme', 'dark')
        }
      })()
    </script>
  </head>
  <body class={`bg-bg text-fg font-mono text-[13px] leading-[1.6] selection:bg-accent/30 antialiased ${fullHeight ? 'overflow-hidden' : ''}`}>
    <div class={shellClass}>
      <header class="flex items-center gap-6 text-[11px] text-muted mb-4 shrink-0">
        <a href="/" class="text-fg hover:text-accent transition-colors tracking-[0.1em] uppercase">cathedral</a>
        <span class="text-dim">·</span>
        <a href="/mine" class="hover:text-fg transition-colors">mine</a>
        <a href="/roadmap" class="hover:text-fg transition-colors">roadmap</a>
        <a href="/changelog" class="hover:text-fg transition-colors">changelog</a>
        <a href="https://github.com/bigailabs/cathedral" class="hover:text-fg transition-colors">github</a>
        <span class="flex-1"></span>
        <button
          type="button"
          data-theme-toggle
          class="text-dim hover:text-fg transition-colors tracking-[0.05em] uppercase text-[10px]"
          aria-label="Toggle theme"
        >
          <span data-theme-icon-dark>◐ dark</span>
          <span data-theme-icon-light class="hidden">◑ light</span>
        </button>
        <span class="text-dim">sn39 · finney</span>
      </header>
      <main class={mainClass}>
        <slot />
      </main>
      <footer class={footerClass}>
        <span>cathedral.computer</span>
        <span class="text-border">·</span>
        <a href="https://github.com/bigailabs/cathedral" class="hover:text-muted transition-colors">source</a>
        <a href="https://github.com/bigailabs/cathedral/blob/main/docs/policy.md" class="hover:text-muted transition-colors">policy</a>
        <span class="flex-1"></span>
        <span>operated by <a href="https://polaris.computer" class="hover:text-muted transition-colors underline decoration-dim underline-offset-2 decoration-[0.5px]">polaris</a></span>
      </footer>
    </div>
    <script is:inline>
      (function () {
        var btn = document.querySelector('[data-theme-toggle]')
        if (!btn) return
        var iconDark = document.querySelector('[data-theme-icon-dark]')
        var iconLight = document.querySelector('[data-theme-icon-light]')
        function sync() {
          var t = document.documentElement.getAttribute('data-theme')
          if (t === 'light') {
            iconDark.classList.add('hidden')
            iconLight.classList.remove('hidden')
          } else {
            iconDark.classList.remove('hidden')
            iconLight.classList.add('hidden')
          }
        }
        sync()
        btn.addEventListener('click', function () {
          var next = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light'
          document.documentElement.setAttribute('data-theme', next)
          try { localStorage.setItem('theme', next) } catch (_) {}
          sync()
        })
      })()
    </script>
    <style is:global>
      html[data-theme='dark'] {
        color-scheme: dark;
        --bg: #0a0a0a;
        --surface: #121214;
        --border: #1f1f22;
        --fg: #ececef;
        --muted: #a1a1aa;
        --dim: #71717a;
        --accent: #0A84FF;
        --accent-dim: rgba(10, 132, 255, 0.22);
        --warn: #f59e0b;
        --err: #ef4444;
        --scrollbar-thumb: #2a2a2c;
        --scrollbar-thumb-hover: #3a3a3c;
      }
      html[data-theme='light'] {
        color-scheme: light;
        --bg: #faf8f3;
        --surface: #f2efe8;
        --border: #e3dfd5;
        --fg: #1c1c1e;
        --muted: #5c5c66;
        --dim: #8a8a93;
        --accent: #0a66c2;
        --accent-dim: rgba(10, 102, 194, 0.14);
        --warn: #b45309;
        --err: #b91c1c;
        --scrollbar-thumb: #d4cfc3;
        --scrollbar-thumb-hover: #bdb7a9;
      }
      html, body { background: var(--bg); color: var(--fg); }
      * { box-sizing: border-box; }
      a { text-decoration: none; }
      body { font-feature-settings: 'calt' 1, 'ss02' 1, 'zero' 1; }
      ::-webkit-scrollbar { width: 6px; height: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--scrollbar-thumb-hover); }
    </style>
  </body>
</html>
