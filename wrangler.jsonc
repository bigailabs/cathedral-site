{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cathedral-site",
  "compatibility_date": "2026-04-17",
  "compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
